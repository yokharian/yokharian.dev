---
/**
 * Experience/Service Card Component
 * Displays professional services with gradient backgrounds and tags
 * Based on the design from the PRD ui-styling-prd.md
 */

export interface Props {
  title: string;
  description: string;
  tags: string[];
  variant: 'blue' | 'green' | 'purple';
  icon: 'check' | 'star' | 'globe' | 'cloud' | 'ai';
}

const { title, description, tags, variant, icon } = Astro.props;

// Variant-based styling
const variantStyles = {
  blue: {
    bg: 'bg-gradient-to-br from-blue-50 to-blue-100',
    iconBg: 'bg-blue-500',
    tagBg: 'bg-blue-100',
    tagText: 'text-blue-800'
  },
  green: {
    bg: 'bg-gradient-to-br from-green-50 to-green-100',
    iconBg: 'bg-green-500',
    tagBg: 'bg-green-100',
    tagText: 'text-green-800'
  },
  purple: {
    bg: 'bg-gradient-to-br from-purple-50 to-purple-100',
    iconBg: 'bg-purple-500',
    tagBg: 'bg-purple-100',
    tagText: 'text-purple-800'
  }
};

const styles = variantStyles[variant];

// Icon SVG paths
const iconPaths = {
  check: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z',
  star: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
  globe: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.94-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z',
  cloud: 'M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z',
  ai: 'M21 10.5V6l-3 4h2c0 3.31-2.69 6-6 6s-6-2.69-6-6 2.69-6 6-6c1.66 0 3.16.67 4.24 1.76l1.42-1.42C18.28 2.96 16.24 2 14 2c-4.42 0-8 3.58-8 8s3.58 8 8 8 8-3.58 8-8h2l-3-3.5zM12 8v5l4.25 2.52.77-1.28-3.52-2.09V8H12z'
};
---

<div class={`${styles.bg} rounded-2xl p-8 text-center group hover-lift hover-glow transition-all duration-300 h-full flex flex-col`}>
  <div class={`w-16 h-16 ${styles.iconBg} rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300`}>
    <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
      <path d={iconPaths[icon]} />
    </svg>
  </div>
  
  <h3 class="text-xl font-bold text-gray-900 mb-2">{title}</h3>
  
  <p class="text-gray-600 mb-4 flex-grow">{description}</p>
  
  <div class="flex flex-wrap justify-center gap-2 mt-auto">
    {tags.map((tag) => (
      <span class={`px-3 py-1 ${styles.tagBg} ${styles.tagText} rounded-full text-sm font-medium`}>
        {tag}
      </span>
    ))}
  </div>
</div>

