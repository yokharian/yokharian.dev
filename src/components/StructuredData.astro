---
export interface Props {
  type: "BlogPosting" | "Person" | "WebSite";
  data: any;
}

const { type, data } = Astro.props;

let structuredData = {};

if (type === "BlogPosting") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.description,
    author: {
      "@type": "Person",
      name: data.author || "Sofia Escobedo",
      url: "https://yokharian.dev/about",
    },
    datePublished: data.pubDatetime.toISOString(),
    dateModified: data.modDatetime?.toISOString() || data.pubDatetime.toISOString(),
    publisher: {
      "@type": "Person",
      name: "Sofia Escobedo",
      logo: {
        "@type": "ImageObject",
        url: "https://yokharian.dev/yokharian-avatar.webp",
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": data.url,
    },
    image: data.ogImage || "https://yokharian.dev/yokharian-avatar.webp",
    articleSection: data.tags?.[0] || "Technology",
    keywords: data.tags?.join(", ") || "",
    wordCount: data.wordCount,
    timeRequired: data.readingTime,
  };
} else if (type === "Person") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Sofia Escobedo",
    url: "https://yokharian.dev",
    image: "https://yokharian.dev/yokharian-avatar.webp",
    sameAs: [
      "https://github.com/yokharian",
      "https://x.com/yokharian",
      "https://bsky.app/profile/yokharian.dev",
    ],
    jobTitle: "Software Engineer",
    description:
      "Backend and cloud engineer with 5+ years of experience on AWS and Python",
  };
} else if (type === "WebSite") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Sofia Escobedo",
    url: "https://yokharian.dev",
    description:
      "Backend and cloud engineer with 5+ years of experience on AWS and Python",
    author: {
      "@type": "Person",
      name: "Sofia Escobedo",
    },
    potentialAction: {
      "@type": "SearchAction",
      target: "https://yokharian.dev/search?q={search_term_string}",
      "query-input": "required name=search_term_string",
    },
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />